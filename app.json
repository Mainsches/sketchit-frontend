{
  "expo": {
    "name": "sketchIT",
    "slug": "sketchit",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sketchit",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.anonymous.sketchit",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca4e424d-d395-46b5-988d-250ac55bc9ef"
      }
    }
  }
}
